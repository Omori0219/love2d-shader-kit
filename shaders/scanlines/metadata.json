{
  "schemaVersion": 1,
  "id": "scanlines",
  "name": "Scanlines",
  "summary": "Adds animated horizontal scanlines to a rendered scene.",
  "description": "Modulates brightness with a screen-space sine wave and a subtle moving phase. It can be used alone or layered with other post-processing for retro display effects.",
  "category": "screen",
  "target": "screen",
  "tags": [
    "screen",
    "scanlines",
    "retro",
    "display"
  ],
  "passes": 1,
  "loveVersion": "11.5",
  "license": "MIT",
  "notes": [],
  "uniforms": [
    {
      "name": "time",
      "type": "float",
      "default": 0.0,
      "description": "Animation time in seconds.",
      "source": "time"
    },
    {
      "name": "spacing",
      "type": "float",
      "default": 3.0,
      "description": "Distance between scanline peaks in screen pixels.",
      "control": {
        "min": 1.5,
        "max": 12.0,
        "step": 0.25
      }
    },
    {
      "name": "strength",
      "type": "float",
      "default": 0.28,
      "description": "Maximum brightness reduction.",
      "control": {
        "min": 0.0,
        "max": 0.9,
        "step": 0.02
      }
    },
    {
      "name": "speed",
      "type": "float",
      "default": 1.3,
      "description": "Vertical phase animation speed.",
      "control": {
        "min": 0.0,
        "max": 8.0,
        "step": 0.1
      }
    }
  ]
}
