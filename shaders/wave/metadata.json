{
  "schemaVersion": 1,
  "id": "wave",
  "name": "Wave",
  "summary": "Distorts a sprite with a smooth animated two-axis wave.",
  "description": "Offsets texture coordinates with sine and cosine waves. The amplitude is expressed in source pixels, so the effect remains predictable across texture sizes.",
  "category": "sprite",
  "target": "sprite",
  "tags": [
    "sprite",
    "distortion",
    "wave",
    "animation"
  ],
  "passes": 1,
  "loveVersion": "11.5",
  "license": "MIT",
  "notes": [],
  "uniforms": [
    {
      "name": "texelSize",
      "type": "vec2",
      "default": [
        0.0078125,
        0.0078125
      ],
      "description": "Reciprocal width and height of the source texture.",
      "source": "texture_texel_size"
    },
    {
      "name": "time",
      "type": "float",
      "default": 0.0,
      "description": "Animation time in seconds.",
      "source": "time"
    },
    {
      "name": "amplitude",
      "type": "float",
      "default": 3.0,
      "description": "Maximum displacement in source pixels.",
      "control": {
        "min": 0.0,
        "max": 12.0,
        "step": 0.25
      }
    },
    {
      "name": "frequency",
      "type": "float",
      "default": 18.0,
      "description": "Number of wave oscillations across the texture.",
      "control": {
        "min": 2.0,
        "max": 40.0,
        "step": 1.0
      }
    },
    {
      "name": "speed",
      "type": "float",
      "default": 2.2,
      "description": "Animation speed.",
      "control": {
        "min": 0.0,
        "max": 8.0,
        "step": 0.1
      }
    }
  ]
}
